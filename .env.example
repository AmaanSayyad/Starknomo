# Starknet Sepolia Configuration
# For Cartridge/Social wallet deposits, use Alchemy (dRPC often returns "unknown block tag 'pre_confirmed'"):
# 1. Go to https://dashboard.alchemy.com -> Create app -> Starknet Sepolia
# 2. Copy API key, replace YOUR_ALCHEMY_KEY below
# NEXT_PUBLIC_STARKNET_SEPOLIA_RPC=https://starknet-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
# STARKNET_SEPOLIA_RPC_SERVER=https://starknet-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
NEXT_PUBLIC_STARKNET_SEPOLIA_RPC=https://starknet-sepolia.drpc.org
STARKNET_SEPOLIA_RPC_SERVER=https://starknet-sepolia.drpc.org
NEXT_PUBLIC_STARKNET_SEPOLIA_CHAIN_ID=0x534e5f5345504f4c4941
NEXT_PUBLIC_STARKNET_SEPOLIA_EXPLORER=https://sepolia.voyager.online
NEXT_PUBLIC_STARKNET_CURRENCY=STRK
NEXT_PUBLIC_STARKNET_CURRENCY_SYMBOL=STRK
NEXT_PUBLIC_STARKNET_CURRENCY_DECIMALS=18
NEXT_PUBLIC_STRK_TOKEN_ADDRESS=0x04718f5a0fc34cc1af16a1cdee98ffb20c31f5cd61d6ab07201858f4287c938d

# Starknet.js Wallet Configuration
NEXT_PUBLIC_STARKNET_WALLET_CONNECTOR=braavos
NEXT_PUBLIC_STARKNET_CHAIN_ID=SN_SEPOLIA

# Treasury Configuration (Starknet account) — server-side withdrawals
STARKNET_TREASURY_ADDRESS=0x_your_treasury_address
STARKNET_TREASURY_PRIVATE_KEY=0x_your_treasury_private_key
NEXT_PUBLIC_STARKNET_TREASURY_ADDRESS=0x_your_treasury_address

# Optional aliases (same as treasury if single wallet)
# DEPLOYER_WALLET_ADDRESS=0x_your_deployer_address
# DEPLOYER_PRIVATE_KEY=0x_your_deployer_private_key

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Application Configuration
NEXT_PUBLIC_APP_NAME=Starknomo
NEXT_PUBLIC_STARKNET_NETWORK=sepolia
NEXT_PUBLIC_ROUND_DURATION=30
NEXT_PUBLIC_PRICE_UPDATE_INTERVAL=1000
NEXT_PUBLIC_CHART_TIME_WINDOW=300000
STARKNET_TREASURY_CAIRO_VERSION=1
